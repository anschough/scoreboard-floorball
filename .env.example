# Kopiera denna fil till .env och fyll i värdena för lokal körning.
# .env är gitignorerad och checkas ALDRIG in. På Render sätts samma
# variabler i tjänstens dashboard (Environment).

# Delat lösenord för kontroll-/inställningssidorna. MÅSTE sättas – lämnas
# det tomt körs appen olåst.
APP_PASSWORD=

# Hemlighet som signerar session-cookies. MÅSTE sättas när APP_PASSWORD är satt,
# och ska vara ett långt SLUMPAT värde (minst 32 tecken) som är frikopplat från
# lösenordet – annars kan en läckt cookie användas för att knäcka lösenordet offline.
# Generera ett: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Sessions-epok (valfri, default 1). Höj värdet (t.ex. till 2) för att omedelbart
# logga ut ALLA – byt om en cookie misstänks ha läckt.
SESSION_EPOCH=1

# Valfri API-nyckel så Stream Deck/automation kan anropa /api/* utan cookie.
# Skicka som headern X-API-Key (rekommenderas). ?key=... i URL:en stöds för
# bakåtkompatibilitet men avråds – URL:er hamnar i loggar. Lämna tom om oanvänd.
API_KEY=
