# Kopiera denna fil till .env och fyll i värdena för lokal körning.
# .env är gitignorerad och checkas ALDRIG in. På Render sätts samma
# variabler i tjänstens dashboard (Environment).

# Delat lösenord för kontroll-/inställningssidorna. MÅSTE sättas – lämnas
# det tomt körs appen olåst.
APP_PASSWORD=

# Hemlighet som signerar session-cookies (valfri). Härleds från lösenordet
# om den lämnas tom. Sätt ett eget långt slumpvärde för full kontroll.
SESSION_SECRET=

# Valfri API-nyckel så Stream Deck/automation kan anropa /api/* utan cookie
# (skickas som ?key=... eller header X-API-Key). Lämna tom om den inte används.
API_KEY=
